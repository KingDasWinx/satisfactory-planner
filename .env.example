# =========================
# Banco de dados (Postgres)
# =========================
# Obrigatório para salvar na nuvem (Prisma + Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# =========================
# Auth.js / NextAuth v5
# =========================
# Obrigatório para autenticação
AUTH_SECRET="troque-por-um-segredo-longo"

# Necessário em alguns hosts/proxies (ex.: produção atrás de reverse proxy)
AUTH_TRUST_HOST="true"

# =========================
# OAuth (opcional)
# =========================
# Se você definir ambos, o botão/provedor aparece no login

# GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

